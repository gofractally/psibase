  {
    "sender": "docs",
    "service": "sites",
    "method": "setcsp",
    "data": {
      "path": "*",
      "csp": "default-src 'self';script-src 'self' 'unsafe-inline' cdnjs.cloudflare.com cdn.jsdelivr.net;style-src 'self' 'unsafe-inline';img-src 'self' data:;font-src 'self' cdnjs.cloudflare.com;connect-src 'self';frame-src 'none';frame-ancestors 'self';base-uri 'none';form-action 'self';object-src 'none';"
    }
  }
]
