package homepage:plugin;

interface name-market {
    use host:types/types.{error};

    /// Purchases a account name, claims it, configures auth-sig, and returns the new account's private key.
    ///
    /// The account is imported onto this device.
    claim-and-set-key: func(account: string) -> result<string, error>;
}

world imports {
    import name-market;
}
