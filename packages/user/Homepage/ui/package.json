{
    "name": "@psibase/homepage-ui",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "vite",
        "build": "node ../../../if-build-needed.mjs 'tsc -b --noEmit && vite build'",
        "lint": "eslint .",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:transport-v2": "vitest run src/apps/chat/transport-v2",
        "e2e": "playwright test --config e2e/playwright.config.ts",
        "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
        "e2e:dm-click-debug": "playwright test --config e2e/playwright.config.ts e2e/tests/chat-dm-sidebar-click-debug.spec.ts",
        "e2e:mesh:three-party": "playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party.spec.ts",
        "e2e:random-churn": "PSIBASE_E2E_RANDOM_CHURN_RUNS=${PSIBASE_E2E_RANDOM_CHURN_RUNS:-2} playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party-random.spec.ts",
        "e2e:random-churn:mesh": "PSIBASE_E2E_RANDOM_CHURN_RUNS=${PSIBASE_E2E_RANDOM_CHURN_RUNS:-1} PSIBASE_E2E_RANDOM_CHURN_SPEED=mesh PSIBASE_E2E_RANDOM_CHURN_STRICT=1 playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party-random.spec.ts",
        "e2e:random-churn:decaf": "PSIBASE_E2E_RANDOM_CHURN_RUNS=1 PSIBASE_E2E_RANDOM_CHURN_SEED=0xdecafbad PSIBASE_E2E_RANDOM_CHURN_SPEED=mesh PSIBASE_E2E_RANDOM_CHURN_STRICT=1 PSIBASE_E2E_RANDOM_CHURN_LEGACY_PLAN=1 PSIBASE_E2E_RANDOM_CHURN_OFFLINE=1 PSIBASE_E2E_RANDOM_CHURN_TIMEOUT_SEC=4800 playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party-random.spec.ts",
        "e2e:delivery-gate": "playwright test --config e2e/playwright.config.ts e2e/tests/chat-three-party-pending-delivery-matrix.spec.ts e2e/tests/chat-dm-pending-flush-on-rejoin.spec.ts e2e/tests/chat-dm-send-before-peer-join.spec.ts e2e/tests/chat-group-offline-member-catchup.spec.ts e2e/tests/chat-three-party-online-offline-flow.spec.ts",
        "e2e:random-churn:diag:wedge": "PSIBASE_E2E_RANDOM_CHURN_RUNS=1 PSIBASE_E2E_RANDOM_CHURN_SEED=0xdecafbad PSIBASE_E2E_RANDOM_CHURN_SPEED=mesh PSIBASE_E2E_RANDOM_CHURN_STRICT=1 PSIBASE_E2E_RANDOM_CHURN_LEGACY_PLAN=1 PSIBASE_E2E_RANDOM_CHURN_DISABLE_RECYCLE=1 PSIBASE_E2E_RANDOM_CHURN_DIAG_STEPS=11-13 PSIBASE_E2E_RANDOM_CHURN_DIAG_STOP_AT=13 PSIBASE_E2E_RANDOM_CHURN_DIAG_STEP_MS=300000 PSIBASE_E2E_RANDOM_CHURN_HUMAN_MS=3000 playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party-random.spec.ts",
        "e2e:random-churn:stress": "PSIBASE_E2E_RANDOM_CHURN_RUNS=${PSIBASE_E2E_RANDOM_CHURN_RUNS:-1} PSIBASE_E2E_RANDOM_CHURN_SPEED=stress PSIBASE_E2E_RANDOM_CHURN_STRICT=0 playwright test --config e2e/playwright.config.ts e2e/tests/chat-group-three-party-random.spec.ts",
        "e2e:random-churn:watch": "bash e2e/scripts/run-random-churn-watchdog.sh",
        "e2e:random-churn:watch:mesh": "PSIBASE_E2E_RANDOM_CHURN_SPEED=mesh PSIBASE_E2E_RANDOM_CHURN_TIMEOUT_SEC=1200 bash e2e/scripts/run-random-churn-watchdog.sh"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.1.1",
        "@psibase/common-lib": "workspace:*",
        "@radix-ui/react-select": "^2.2.5",
        "@react-spring/web": "^10.0.1",
        "@tanstack/react-form": "^1.19.3",
        "@tanstack/react-pacer": "^0.16.1",
        "@tanstack/react-query": "^5.90.6",
        "cmdk": "^1.1.1",
        "dayjs": "^1.11.13",
        "framer-motion": "^11.0.24",
        "jotai": "^2.12.2",
        "lucide-react": "^0.475.0",
        "react": "^19.1.0",
        "react-confetti-explosion": "^2.1.2",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.58.1",
        "react-router-dom": "^6.26.1",
        "usehooks-ts": "^3.1.1",
        "vaul": "^1.1.2",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/node": "^22.15.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@types/react-router-dom": "5.3.3",
        "eslint": "^9.15.0",
        "happy-dom": "^17.4.4",
        "typescript": "^5.7.3",
        "vite": "^5.4.1",
        "vite-plugin-svgr": "^4.3.0",
        "vitest": "^3.1.1"
    }
}
