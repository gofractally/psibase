{
  "version": 1,
  "entities": {
    "published_package": {
      "label": "Published package (.psi)",
      "namespace": "artifact",
      "convention": "PascalCase; output filename is case-sensitive",
      "constraints": ["pascalCase"]
    },
    "package_crate": {
      "label": "Package crate",
      "namespace": "cargo",
      "convention": "kebab-case with `-pkg` suffix (e.g. `name-market-pkg`)",
      "constraints": ["cargoCrateName"]
    },
    "service_crate": {
      "label": "Service crate",
      "namespace": "cargo",
      "convention": "kebab-case (e.g. `name-market`)",
      "constraints": ["kebabCase"]
    },
    "query_crate": {
      "label": "Query crate",
      "namespace": "cargo",
      "convention": "kebab-case with `r-` prefix (e.g. `r-name-market`); often abbreviated with on-chain account",
      "constraints": ["kebabCase"]
    },
    "plugin_crate": {
      "label": "Plugin crate",
      "namespace": "cargo",
      "convention": "kebab-case with `-plugin` suffix (e.g. `name-market-plugin`)",
      "constraints": ["kebabCase"]
    },
    "wit_package": {
      "label": "WIT component package",
      "namespace": "wit",
      "convention": "kebab-case service crate + `:plugin` (e.g. `name-market:plugin`); independent of on-chain account",
      "constraints": ["witPackage"]
    },
    "on_chain_service": {
      "label": "On-chain service account",
      "namespace": "chain",
      "convention": "≤10 chars; `a-z`, `0-9`, `-`; no leading/trailing/double hyphen; often abbreviated vs service crate",
      "constraints": ["accountNumber"]
    },
    "on_chain_query": {
      "label": "On-chain query account",
      "namespace": "chain",
      "convention": "`{on-chain-service}+N` subaccount format; `+1` is usual",
      "constraints": ["accountNumberSubaccount"]
    }
  },
  "correlationGroups": [
    {
      "id": "published_package",
      "entity": "published_package",
      "description": "Published `.psi` artifact name"
    },
    {
      "id": "package_crate",
      "entity": "package_crate",
      "description": "Root package Cargo crate name"
    },
    {
      "id": "service_crate",
      "entity": "service_crate",
      "description": "Service Cargo crate name (per `services[]` entry)",
      "perService": true
    },
    {
      "id": "query_crate",
      "entity": "query_crate",
      "description": "Query-service Cargo crate name",
      "perService": true
    },
    {
      "id": "plugin_crate",
      "entity": "plugin_crate",
      "description": "Plugin Cargo crate name",
      "perService": true,
      "optional": true
    },
    {
      "id": "wit_package",
      "entity": "wit_package",
      "description": "WIT / component package identifier",
      "perService": true,
      "optional": true
    },
    {
      "id": "on_chain_service",
      "entity": "on_chain_service",
      "description": "On-chain service account",
      "perService": true
    },
    {
      "id": "on_chain_query",
      "entity": "on_chain_query",
      "description": "On-chain query account",
      "perService": true,
      "transformFrom": "on_chain_service",
      "transform": "subaccountPlusOne"
    }
  ]
}
